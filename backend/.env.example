# Cordis — Environment Configuration
# Copy to .env and fill in values

# ---- Required ----
SECRET_KEY=your-secret-key-here

# ---- Database ----
USE_SQLITE=true
POSTGRES_USER=cordis
POSTGRES_PASSWORD=
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cordis_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Gemini (for logistics pipeline) ----
# Option A: Gemini Developer API key
GEMINI_API_KEY=
# Option B: Vertex AI (leave GEMINI_API_KEY empty)
# VERTEX_AI_PROJECT=your-gcp-project
# VERTEX_AI_LOCATION=us-central1

# ---- Logistics ----
LOGISTICS_ENABLED=true
GEMINI_MODEL=gemini-2.0-flash
MAX_AGENT_ITERATIONS=10
PIPELINE_TIMEOUT_SECONDS=270

# ---- Optional services ----
GROQ_API_KEY=
WHISPER_MODEL_SIZE=small
