# Auto detect text files and normalize line endings
* text=auto

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.onnx binary
*.pt binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
